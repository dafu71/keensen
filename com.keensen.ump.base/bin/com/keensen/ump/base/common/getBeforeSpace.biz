    <targetConnections>link2</targetConnections>
    <nodeLabel>assign1label</nodeLabel>
    <process:copy>
      <process:from type="expression" pattern="reference">str.substring(0, Math.min(spaceIndex, fullSpaceIndex))</process:from>
