      </process:transitionCondition>
    </sourceConnections>
    <targetConnections>link0</targetConnections>
    <nodeLabel>assign0label</nodeLabel>
    <process:copy>
      <process:from type="expression" pattern="reference">str.indexOf(&quot; &quot;)</process:from>
      <process:to type="query">spaceIndex</process:to>
