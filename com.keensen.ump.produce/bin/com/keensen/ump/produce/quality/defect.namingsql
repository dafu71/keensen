	order by zr.record_id,t1.create_time
	 </select>
    <select id="queryMpDefect4Cdm" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">
   	
    SELECT T1.ID              AS "defectId",
       to_char(t1.create_time,'yyyy-MM-dd') "createTime",
       T1.CREATE_USER_ID  AS "createUserId",
       T1.CREATE_NAME     AS "createName",
       to_char(t1.UPDATE_TIME,'yyyy-MM-dd') "updateTime",
       T1.UPDATE_USER_ID  AS "updateUserId",
       T1.UPDATE_NAME     AS "updateName",
       T1.RESERVE1        AS "reserve1",
       T1.RESERVE2        AS "reserve2",
       T1.RESERVE3        AS "reserve3",
       T1.RESERVE4        AS "reserve4",
       T1.RESERVE5        AS "reserve5",
       T1.ORG_ID          AS "orgId",
       T1.STATUS          AS "status",
       t1.FIRST as "first",
		t1.SECOND as "second",
		t1.THIRD as "third",
		t1.FOURTH as "fourth",
		0 as "length",
		'裁叠膜' as "tacheCause"

  FROM KS_QUALITY_MP_DEFECT T1
	where 1=1
	
	<isNotNull prepend="and" property="tache">T1.tache = #tache#</isNotNull>
        <isNotNull prepend="and" property="createTimeStart">TO_CHAR(T1.CREATE_TIME, 'yyyy-MM-dd')  &gt;=  #createTimeStart#</isNotNull>
        <isNotNull prepend="and" property="createTimeEnd">TO_CHAR(T1.CREATE_TIME, 'yyyy-MM-dd')  &lt;=  #createTimeEnd#</isNotNull>
        <isNotNull prepend="and" property="id">T1.ID = #id#</isNotNull>
        <isNotNull prepend="and" property="first">t1.first = #first#</isNotNull>
        <isNotNull prepend="and" property="second">t1.second like '%' || #second# || '%'</isNotNull>
        <isNotNull prepend="and" property="third">t1.third like '%' || #third# || '%'</isNotNull>
        <isNotNull prepend="and" property="fourth">t1.fourth '%' || #fourth# || '%'</isNotNull>
        <isNotNull prepend="and" property="advise">t1.advise '%' || #advise# || '%'</isNotNull>
	
	order by t1.first,t1.second,t1.third,t1.fourth
	 </select>
