	where 1=1
	
	<isNotNull prepend="and" property="iftear">t1.iftear = #iftear#</isNotNull>
        <isNotNull prepend="and" property="lineName">l.line_name || '(' || l.line_code || ')' like '%' || #lineName# || '%'</isNotNull>
