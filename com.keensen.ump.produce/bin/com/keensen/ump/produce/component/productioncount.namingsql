<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">
<sqlMap namespace="com.keensen.ump.produce.component.productioncount">
    <select id="queryProductionCdm" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">
    SELECT T1.ID                 AS "id",

       to_char(t1.create_time,'yyyy-MM-dd') "createTime",
       T1.CREATE_USER_ID     AS "createUserId",
       T1.CREATE_NAME        AS "createName",
    
       to_char(T1.UPDATE_TIME,'yyyy-MM-dd') "updateTime",
       T1.UPDATE_USER_ID     AS "updateUserId",
       T1.UPDATE_NAME        AS "updateName",
       T1.RESERVE1           AS "reserve1",
       T1.RESERVE2           AS "reserve2",
       T1.RESERVE3           AS "reserve3",
       T1.RESERVE4           AS "reserve4",
       T1.RESERVE5           AS "reserve5",
       T1.ORG_ID             AS "orgId",
       T1.STATUS             AS "status",
       t1.user_id as "userId",
		t1.user_name as "userName",
		 to_char(t1.date_count,'yyyy-MM-dd') as "dateCount",
		TO_CHAR(t1.time_start, 'yyyy-MM-dd HH24:mi:ss') as "timeStart",
		TO_CHAR(t1.time_end, 'yyyy-MM-dd HH24:mi:ss') as "timeEnd",
		t1.quantity as "quantity",
		t1.confirm_user_id as "confirmUserId",
		t1.confirm_user_name as "confirmUserName",
		t1.confirm_time as "confirmTime",
		t1.confirm_user_id2 as "confirmUserId2",
		t1.confirm_user_name2 as "confirmUserName2",
		t1.confirm_time2 as "confirmTime2",
		t1.confirm_user_id3 as "confirmUserId3",
		t1.confirm_user_name3 as "confirmUserName3",
		t1.confirm_time3 as "confirmTime3",
		
		case when to_char(t1.date_count,'yyyy-MM-dd') = to_char(sysdate,'yyyy-MM-dd')
		then 1
		else 0 end "ifExistToday"
		
		from KS_COMPONENT_PRODUCTION_CDM t1
		where 1=1
		<isNotNull prepend="and" property="id">t1.id = #id#</isNotNull>
        <!--检查开机信息-->
        <isEqual compareValue="1" prepend="" property="checkstart">and t1.id = (select max(id) from KS_COMPONENT_PRODUCTION_CDM
		       where user_id = #userId#)</isEqual>
    </select>
    <insert id="insertProductionCdmList" parameterClass="java.util.HashMap">INSERT INTO KS_COMPONENT_PRODUC_CDM_LIST
  (ID,
   RELATION_ID,
   TUMO_BATCH_ID,
   PROD_SPEC_ID,
   BATCH_NO,
   PRO_SPEC_NAME,
   QUANTITY)
  SELECT SEQ_COMPONENT_PRODUC_CDM_LIST.NEXTVAL,
         #relationId#,
         TUMO_BATCH_ID,
         PROD_SPEC_ID,
         TM.BATCH_NO,
         PMS.MATER_SPEC_NAME,
         QUANTITY
    FROM (SELECT TUMO_BATCH_ID, PROD_SPEC_ID, SUM(QUANTITY) QUANTITY
            FROM (SELECT T.RECORD_ID,
                         TO_CHAR(T.create_dt, 'YYYY-MM-DD') create_dt,
                         T.TEAM_ID,
                         T.WORKER_ID,
                         T.QUANTITY,
                         T.TUMO_BATCH_ID,
                         T.PROD_SPEC_ID
                    FROM QINSEN.INST_CAIDIEMO T
                   WHERE TO_CHAR(T.create_dt, 'YYYY-MM-DD HH24:MI') &gt;=
                         (SELECT TO_CHAR(TIME_START, 'YYYY-MM-DD HH24:MI')
                            FROM KS_COMPONENT_PRODUCTION_CDM
                           WHERE ID = #relationId#)
                     AND TO_CHAR(T.create_dt, 'YYYY-MM-DD HH24:MI') &lt;=
                         (SELECT TO_CHAR(TIME_END, 'YYYY-MM-DD HH24:MI')
                            FROM KS_COMPONENT_PRODUCTION_CDM
                           WHERE ID = #relationId#)
                     AND T.WORKER_ID = (SELECT EMPID
                                          FROM KS_COMPONENT_PRODUCTION_CDM CM
                                          LEFT JOIN V_AC_OPERATOR_TRS V
                                            ON V.USERID = CM.USER_ID
                                         WHERE ID = #relationId#))
           GROUP BY TUMO_BATCH_ID, PROD_SPEC_ID) CM
    LEFT JOIN QINSEN.INST_TUMO TM
      ON CM.TUMO_BATCH_ID = TM.RECORD_ID
    LEFT JOIN QINSEN.PARA_MATER_SPEC PMS
      ON PMS.MATER_SPEC_ID = CM.PROD_SPEC_ID</insert>
    <select id="queryProducCdmList" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">
 
 SELECT h.user_name "userName",to_char(h.date_count,'YYYY-MM-DD') "dataCount",
	t.batch_no "batchNo",t.pro_spec_name "prodSpecName",t.quantity "quantity",
	to_char(h.time_start,'YYYY-MM-DD HH24:MI:SS') "timeStart",
	to_char(h.time_end,'YYYY-MM-DD HH24:MI:SS') "timeEnd",
	h.user_id,t.id "id",t.relation_id "relationId"
	FROM KS_COMPONENT_PRODUC_CDM_LIST t
	LEFT JOIN KS_COMPONENT_PRODUCTION_CDM h
	ON t.relation_id = h.id
 	where 1=1
		<isNotNull prepend="and" property="id">h.id = #id#</isNotNull>
        <isNotNull prepend="and" property="userId">h.user_id = #userId#</isNotNull>
        <isNotNull prepend="and" property="prodSpecId">t.pro_spec_id = #prodSpecId#</isNotNull>
        <isNotNull prepend="and" property="userName">h.user_name like '%' || #userName# || '%'</isNotNull>
        <isNotNull prepend="and" property="prodSpecName">t.pro_spec_name like '%' || #prodSpecName# || '%'</isNotNull>
        <isNotNull prepend="and" property="batchNo">t.batch_no like '%' || #batchNo# || '%'</isNotNull>
        <isNotNull prepend="and" property="dateCountStart">to_char(h.date_count,'yyyy-MM-dd')  &gt;=  #dateCountStart#</isNotNull>
        <isNotNull prepend="and" property="dateCountEnd">to_char(h.date_count,'yyyy-MM-dd')  &lt;=  #dateCountEnd#</isNotNull>
     order by h.user_name , to_char(h.date_count,'YYYY-MM-DD')
 </select>
    <select id="countProducCdmList" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">
 
 SELECT sum(t.quantity) "quantityTotal"
	FROM KS_COMPONENT_PRODUC_CDM_LIST t
	LEFT JOIN KS_COMPONENT_PRODUCTION_CDM h
	ON t.relation_id = h.id
 	where 1=1
		<isNotNull prepend="and" property="id">h.id = #id#</isNotNull>
        <isNotNull prepend="and" property="userId">h.user_id = #userId#</isNotNull>
        <isNotNull prepend="and" property="prodSpecId">t.pro_spec_id = #prodSpecId#</isNotNull>
        <isNotNull prepend="and" property="userName">h.user_name like '%' || #userName# || '%'</isNotNull>
        <isNotNull prepend="and" property="prodSpecName">t.pro_spec_name like '%' || #prodSpecName# || '%'</isNotNull>
        <isNotNull prepend="and" property="batchNo">t.batch_no like '%' || #batchNo# || '%'</isNotNull>
        <isNotNull prepend="and" property="dateCountStart">to_char(h.date_count,'yyyy-MM-dd')  &gt;=  #dateCountStart#</isNotNull>
        <isNotNull prepend="and" property="dateCountEnd">to_char(h.date_count,'yyyy-MM-dd')  &lt;=  #dateCountEnd#</isNotNull>
     order by h.user_name , to_char(h.date_count,'YYYY-MM-DD')
 </select>
    <select id="queryProductRs" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">
