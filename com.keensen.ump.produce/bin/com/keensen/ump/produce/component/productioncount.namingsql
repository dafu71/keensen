    <select id="queryProdType" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">select DISTINCT t.prod_type "prodType" from qinsen.inst_raosi t
WHERE t.prod_type IS NOT NULL
ORDER BY t.prod_type</select>
