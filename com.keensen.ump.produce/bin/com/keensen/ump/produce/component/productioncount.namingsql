    <insert id="insertProductRsList" parameterClass="java.util.HashMap">INSERT INTO KS_COMPONENT_PRODUCt_rs_LIST
	  (ID,
	   RELATION_ID,
	   prod_type,
	   QUANTITY)
	  SELECT SEQ_COMPONENT_PRODUC_RS_LIST.NEXTVAL,
	         #relationId#,
	         prod_type,
	         QUANTITY
	    FROM (select t.prod_type,COUNT(1) quantity from qinsen.inst_raosi t
	                   WHERE TO_CHAR(T.CREATE_DT, 'YYYY-MM-DD HH24:MI') &gt;=
	                         (SELECT TO_CHAR(TIME_START, 'YYYY-MM-DD HH24:MI')
	                            FROM KS_COMPONENT_PRODUCT_RS
	                           WHERE ID = #relationId#)
	                     AND TO_CHAR(T.CREATE_DT, 'YYYY-MM-DD HH24:MI') &lt;=
	                         (SELECT TO_CHAR(TIME_END, 'YYYY-MM-DD HH24:MI')
	                            FROM KS_COMPONENT_PRODUCT_RS
	                           WHERE ID = #relationId#)
	                     AND T.WORKER_ID = (SELECT EMPID
	                                          FROM KS_COMPONENT_PRODUCT_RS RS
	                                          LEFT JOIN V_AC_OPERATOR_TRS V
	                                            ON V.USERID = RS.USER_ID
	                                         WHERE ID = #relationId#)
	           GROUP BY prod_type)</insert>
    <select id="queryProductRsList" parameterClass="java.util.HashMap" resultClass="commonj.sdo.DataObject">
 
 SELECT h.user_name "userName",to_char(h.date_count,'YYYY-MM-DD') "dataCount",
	t.prod_type "prodType",t.quantity "quantity",
	to_char(h.time_start,'YYYY-MM-DD HH24:MI:SS') "timeStart",
	to_char(h.time_end,'YYYY-MM-DD HH24:MI:SS') "timeEnd",
	h.user_id,t.id,t.relation_id "relationId"
	FROM KS_COMPONENT_PRODUCt_rs_LIST t
	LEFT JOIN KS_COMPONENT_PRODUCT_rs h
	ON t.relation_id = h.id
 	where 1=1
		<isNotNull prepend="and" property="id">h.id = #id#</isNotNull>
        <isNotNull prepend="and" property="userId">h.user_id = #userId#</isNotNull>
        <isNotNull prepend="and" property="prodType">t.prod_type = #prodType#</isNotNull>
