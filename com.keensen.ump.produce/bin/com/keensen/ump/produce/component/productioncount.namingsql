    <insert id="insertProductJmList" parameterClass="java.util.HashMap">INSERT INTO KS_COMPONENT_PRODUCT_JM_LIST
  (ID,
   RELATION_ID,
   PROD_SPEC_ID,
   PRO_SPEC_NAME,
   QUANTITY)
  SELECT SEQ_COMPONENT_PRODUCT_JM_LIST.NEXTVAL,
         #relationId#,
         PROD_SPEC_ID,
         PMS.MATER_SPEC_NAME,
         QUANTITY
    FROM (SELECT PROD_SPEC_ID, COUNT(1) QUANTITY
            FROM (SELECT T.RECORD_ID,
                         TO_CHAR(T.create_dt, 'YYYY-MM-DD') create_dt,
                         T.TEAM_ID,
                         T.WORKER_ID,
                         T.PROD_SPEC_ID
                    FROM QINSEN.INST_JUANMO_MAIN T
                   WHERE TO_CHAR(T.create_dt, 'YYYY-MM-DD HH24:MI') &gt;=
                         (SELECT TO_CHAR(TIME_START, 'YYYY-MM-DD HH24:MI')
                            FROM KS_COMPONENT_PRODUCT_JM
                           WHERE ID = #relationId#)
                     AND TO_CHAR(T.create_dt, 'YYYY-MM-DD HH24:MI') &lt;=
                         (SELECT TO_CHAR(TIME_END, 'YYYY-MM-DD HH24:MI')
                            FROM KS_COMPONENT_PRODUCT_JM
                           WHERE ID = #relationId#)
                     AND T.WORKER_ID = (SELECT EMPID
                                          FROM KS_COMPONENT_PRODUCT_JM CM
                                          LEFT JOIN V_AC_OPERATOR_TRS V
                                            ON V.USERID = CM.USER_ID
                                         WHERE ID = #relationId#))
           GROUP BY PROD_SPEC_ID) JM
    
    LEFT JOIN QINSEN.PARA_MATER_SPEC PMS
      ON PMS.MATER_SPEC_ID = JM.PROD_SPEC_ID</insert>
