		then 1
		else 0 end "ifExistToday"
		
		from KS_COMPONENT_PRODUCT_RS t1
		where 1=1
		<isNotNull prepend="and" property="id">t1.id = #id#</isNotNull>
        <!--检查开机信息-->
        <isEqual compareValue="1" prepend="" property="checkstart">and t1.id = (select max(id) from KS_COMPONENT_PRODUCT_RS
