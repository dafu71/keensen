       </select>
       
       <insert id="insertProductHHJmList" parameterClass="java.util.HashMap">
	INSERT INTO KS_COMPONENT_PRODUCT_HHJM_LIST
  (ID,
   RELATION_ID,
   TUMO_BATCH_ID,
   PROD_SPEC_ID,
   BATCH_NO,
   PRO_SPEC_NAME,
   QUANTITY)
  SELECT SEQ_COMPONENT_PROD_HHJM_LIST.NEXTVAL,
         #relationId#,
         TUMO_BATCH_ID,
         PROD_SPEC_ID,
         TM.BATCH_NO,
         PMS.MATER_SPEC_NAME,
         QUANTITY
    FROM (SELECT TUMO_BATCH_ID, PROD_SPEC_ID, SUM(QUANTITY) QUANTITY
            FROM (SELECT T.id RECORD_ID,
                         TO_CHAR(T.create_time, 'YYYY-MM-DD') create_dt,
                         T.WORKER_ID,
                         T.AMOUNT QUANTITY,
                         Tm.Record_Id TUMO_BATCH_ID,
                         T.PROD_SPEC_ID
                    FROM KS_COMPONENT_HOUSEHOLD_JM T
                    LEFT JOIN QINSEN.INST_caidiemo cm
                    ON cm.batch_no = t.cm_batch_no
                    LEFT JOIN qinsen.inst_tumo tm
                    ON tm.record_id = cm.tumo_batch_id
                   WHERE TO_CHAR(T.create_time, 'YYYY-MM-DD HH24:MI') >=
                         (SELECT TO_CHAR(TIME_START, 'YYYY-MM-DD HH24:MI')
                            FROM KS_COMPONENT_PRODUCT_HHJM
                           WHERE ID = #relationId#)
                     AND TO_CHAR(T.create_time, 'YYYY-MM-DD HH24:MI') &lt;=
                         (SELECT TO_CHAR(TIME_END, 'YYYY-MM-DD HH24:MI')
                            FROM KS_COMPONENT_PRODUCT_HHJM
                           WHERE ID = #relationId#)
                     AND T.WORKER_ID = (SELECT EMPID
                                          FROM KS_COMPONENT_PRODUCT_HHJM JM
                                          LEFT JOIN V_AC_OPERATOR_TRS V
                                            ON V.USERID = JM.USER_ID
                                         WHERE ID = #relationId#))
           GROUP BY TUMO_BATCH_ID, PROD_SPEC_ID) JM
    LEFT JOIN QINSEN.INST_TUMO TM
      ON JM.TUMO_BATCH_ID = TM.RECORD_ID
    LEFT JOIN QINSEN.PARA_MATER_SPEC PMS
      ON PMS.MATER_SPEC_ID = JM.PROD_SPEC_ID

</insert>

<select id="queryProductHHJmList" resultClass="commonj.sdo.DataObject" parameterClass="java.util.HashMap" >
 
 SELECT h.user_name "userName",to_char(h.date_count,'YYYY-MM-DD') "dataCount",
	t.batch_no "batchNo",t.pro_spec_name "prodSpecName",t.quantity "quantity",
	to_char(h.time_start,'YYYY-MM-DD HH24:MI:SS') "timeStart",
	to_char(h.time_end,'YYYY-MM-DD HH24:MI:SS') "timeEnd",
	h.user_id,t.id,t.relation_id "relationId"
	FROM KS_COMPONENT_PRODUCT_HHJM_LIST t
	LEFT JOIN KS_COMPONENT_PRODUCT_HHJM h
	ON t.relation_id = h.id
 	where 1=1
		<isNotNull prepend="and" property="id"> 
		       h.id = #id#
		</isNotNull>
		
		<isNotNull prepend="and" property="userId"> 
		       h.user_id = #userId#
		</isNotNull>
		
		<isNotNull prepend="and" property="prodSpecId"> 
		       t.pro_spec_id = #prodSpecId#
		</isNotNull>
		
		<isNotNull prepend="and" property="userName"> 
		       h.user_name like '%' || #userName# || '%'
		</isNotNull>
		
		<isNotNull prepend="and" property="prodSpecName"> 
		       t.pro_spec_name like '%' || #prodSpecName# || '%'
		</isNotNull>
		
		<isNotNull prepend="and" property="batchNo"> 
		       t.batch_no like '%' || #batchNo# || '%'
		</isNotNull>
		
		<isNotNull prepend = "and"  property = "dateCountStart"> 
          to_char(h.date_count,'yyyy-MM-dd')  &gt;=  #dateCountStart#
     </isNotNull>
     <isNotNull prepend = "and"  property = "dateCountEnd"> 
          to_char(h.date_count,'yyyy-MM-dd')  &lt;=  #dateCountEnd#
     </isNotNull>
     order by h.user_name , to_char(h.date_count,'YYYY-MM-DD')
 </select>
 
